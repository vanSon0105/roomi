generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  ADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  ONLINE
  PAYOS
  SEPAY
}

enum PaymentProvider {
  PAYOS
  SEPAY
}

enum PaymentTransactionStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
  FAILED
  PROCESSING
  UNDERPAID
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  phone     String?   @unique
  avatarUrl String?   @db.VarChar(500)
  birthday  DateTime? @db.Date
  password  String
  role      Role      @default(USER)
  isBanned  Boolean   @default(false)
  cart         Cart?
  addresses    Address[]
  orders       Order[]
  chatMessages ChatMessage[]
  createdAt    DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

model Category {
  id          Int        @id @default(autoincrement())
  parentId    Int?
  name        String
  slug        String     @unique
  description String?    @db.Text
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([parentId])
  @@map("categories")
}

model Product {
  id               Int            @id @default(autoincrement())
  categoryId       Int?
  name             String
  slug             String         @unique
  sku              String?        @unique
  shortDescription String?        @db.VarChar(500)
  description      String?        @db.Text
  price            Decimal        @db.Decimal(12, 2)
  compareAtPrice   Decimal?       @db.Decimal(12, 2)
  rating           Decimal        @default(0) @db.Decimal(2, 1)
  stock            Int            @default(0)
  status           ProductStatus  @default(ACTIVE)
  isFeatured       Boolean        @default(false)
  suitableFor      String?        @db.Text
  category         Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images           ProductImage[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
  @@map("products")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  imageUrl  String   @db.VarChar(500)
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, sortOrder])
  @@map("product_images")
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int      @default(1)
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([productId])
  @@map("cart_items")
}

model Address {
  id        Int      @id @default(autoincrement())
  userId    Int
  fullName  String
  phone     String
  line1     String
  line2     String?
  ward      String?
  district  String?
  province  String?
  country   String   @default("Việt Nam")
  isDefault Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]  @relation("OrderShippingAddress")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("addresses")
}

model Order {
  id                  Int                  @id @default(autoincrement())
  code                String               @unique
  userId              Int
  shippingAddressId   Int?
  recipientName       String
  recipientPhone      String
  shippingLine1       String
  shippingLine2       String?
  shippingWard        String?
  shippingDistrict    String?
  shippingProvince    String?
  shippingCountry     String               @default("Việt Nam")
  status              OrderStatus          @default(PENDING)
  paymentStatus       PaymentStatus        @default(UNPAID)
  paymentMethod       PaymentMethod        @default(COD)
  subtotal            Decimal              @db.Decimal(12, 2)
  shippingFee         Decimal              @default(0) @db.Decimal(12, 2)
  discountAmount      Decimal              @default(0) @db.Decimal(12, 2)
  total               Decimal              @db.Decimal(12, 2)
  note                String?              @db.Text
  paymentReportedAt   DateTime?
  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  shippingAddress     Address?             @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  items               OrderItem[]
  paymentTransactions PaymentTransaction[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([userId, status])
  @@index([shippingAddressId])
  @@map("orders")
}

model PaymentTransaction {
  id                    Int                      @id @default(autoincrement())
  orderId               Int
  provider              PaymentProvider          @default(PAYOS)
  providerOrderCode     BigInt?                  @unique
  providerPaymentLinkId String?                  @unique
  checkoutUrl           String?                  @db.VarChar(1000)
  qrCode                String?                  @db.Text
  amount                Decimal                  @db.Decimal(12, 2)
  status                PaymentTransactionStatus @default(PENDING)
  requestPayload        String?                  @db.LongText
  responsePayload       String?                  @db.LongText
  webhookPayload        String?                  @db.LongText
  paidAt                DateTime?
  order                 Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([orderId, provider, status])
  @@map("payment_transactions")
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  productId   Int?
  productName String
  productSku  String?
  unitPrice   Decimal  @db.Decimal(12, 2)
  quantity    Int
  totalPrice  Decimal  @db.Decimal(12, 2)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String @db.Text

  @@map("settings")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int?
  guestId   String?
  name      String   @default("Khách")
  message   String   @db.Text
  isAdmin   Boolean  @default(false)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([guestId, createdAt])
  @@map("chat_messages")
}
